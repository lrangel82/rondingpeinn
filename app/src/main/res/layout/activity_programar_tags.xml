<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ProgramarTags">

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="58dp"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="MissingConstraints"
        tools:layout_editor_absoluteX="0dp">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/editTextText"
                android:layout_width="120dp"
                android:layout_height="48dp"
                android:layout_weight="0"
                android:ems="10"
                android:inputType="text"
                android:text="Descripcion:"
                android:textAlignment="textEnd" />

            <EditText
                android:id="@+id/txtDescripcion"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:ems="10"
                android:inputType="text"
                android:tooltipText="Indicar la descripcion del tag" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtLat"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:ems="10"
                android:text="Latitud"
                android:textAlignment="center" />

            <TextView
                android:id="@+id/txtLon"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:ems="10"
                android:text="Longitud"
                android:textAlignment="center" />

        </LinearLayout>

        <Button
            android:id="@+id/btn_ProgramarTag"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="40dp"
            android:text="Programar TAG nuevo"
            android:textSize="24sp"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/txtlog2"
            android:layout_width="match_parent"
            android:layout_height="70dp" />


        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <fragment
                android:id="@+id/map_fragment_programarTags"
                class="com.google.android.gms.maps.SupportMapFragment"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:mapId="839c8b86b29f05fd"
                app:uiZoomControls="true" />

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:translationY="-20dp"
                android:src="@android:drawable/ic_menu_myplaces"
                android:contentDescription="Puntero central"
                app:tint="@color/design_default_color_primary" />

            <ImageButton
                android:id="@+id/btn_recuperar_gps"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="top|end"
                android:layout_margin="16dp"
                android:background="@android:color/white"
                android:elevation="4dp"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:contentDescription="Mi Posicion"
                app:srcCompat="@android:drawable/ic_menu_mylocation"
                app:tint="@color/design_default_color_primary" />

        </FrameLayout>

        <LinearLayout
            android:id="@+id/linearLayout3"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnSettings"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:contentDescription="Licencia"
                app:srcCompat="@android:drawable/ic_dialog_info" />

            <Button
                android:id="@+id/btn_cerrar"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="Cerrar" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>