<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="?attr/actionBarSize"
    android:layout_marginBottom="?attr/actionBarSize">

    <fragment
        android:id="@+id/nav_host_fragment_activity_main"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:defaultNavHost="true"
        app:navGraph="@navigation/mobile_navigation" />

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshLayoutMain"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="10dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/txtCotoName"
                        android:layout_width="match_parent"
                        android:layout_height="35dp"
                        android:layout_weight="1"
                        android:text="NombreCoto"
                        android:textAlignment="center"
                        android:textAllCaps="true"
                        android:textColor="@color/teal_700"
                        android:textSize="30sp"
                        android:textStyle="bold|italic"
                        tools:ignore="MissingConstraints" />

                    <ImageButton
                        android:id="@+id/btnConfigTag"
                        android:layout_width="50dp"
                        android:layout_height="wrap_content"
                        android:contentDescription="Configuracion"
                        app:srcCompat="@android:drawable/ic_menu_manage" />
                </LinearLayout>

                <Button
                    android:id="@+id/btn_StartRondin"
                    android:layout_width="350dp"
                    android:layout_height="55dp"
                    android:text="Iniciar RONDIN"
                    android:textSize="24sp"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btn_vehiculos"
                    android:layout_width="350dp"
                    android:layout_height="55dp"

                    android:enabled="true"
                    android:text="MAPA"
                    android:textSize="24sp" />

                <ImageView
                    android:id="@+id/imageView"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    app:srcCompat="@drawable/logo_gpeinn_2" />

                <Button
                    android:id="@+id/btn_permisos"
                    android:layout_width="350dp"
                    android:layout_height="55dp"

                    android:text="Permisos"
                    android:textSize="24sp" />

                <Button
                    android:id="@+id/btnIncidenciasMain"
                    android:layout_width="350dp"
                    android:layout_height="55dp"
                    android:text="Incidencias"
                    android:textSize="24sp" />

                <TextView
                    android:id="@+id/textCopyright"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginBottom="16dp"
                    android:text="v0.1 Free develop by Luis Rangel" />
            </LinearLayout>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.constraintlayout.widget.ConstraintLayout>