<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AcercadeActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:id="@+id/imgLogoAbout"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_marginTop="40dp"
            android:src="@drawable/logo" /> <!-- Tu logo de Rondy -->

        <!-- Azul profundo profesional -->

        <TextView
            android:id="@+id/txtVersionInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Versión 1.0.0 (Build 1)"
            android:textSize="14sp"
            android:layout_marginTop="8dp" />

        <View
            android:layout_width="60dp"
            android:layout_height="2dp"
            android:layout_marginVertical="24dp"
            android:background="#4CAF50" /> <!-- Separador verde -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Rondy es el sistema inteligente de gestión de rondines diseñado para la máxima seguridad y control en condominios. Basado en tags de NFC para lectura. En la version Pro, podra ademas llevar control de su parque vehicular, permisos otorgados e incidencias generadas. Para mas informacion contacte con soporte tecnico"
            android:textAlignment="center"
            android:lineSpacingExtra="4dp"
            android:textSize="16sp"
            android:textColor="#555555" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btnContactSupport"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contactar Soporte Técnico"
            android:textColor="#E65100" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>